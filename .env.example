# Configurações do Servidor Web
PORT=3000

# Credenciais do Google Cloud IAM (Service Account JSON)
# ATENÇÃO: O valor deve ser o JSON completo em formato de string (uma única linha).
# Solicite a chave real ao administrador da infraestrutura ou crie uma no painel do GCP.
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"seu-projeto-aqui","private_key_id":"sua-chave-id-aqui","private_key":"-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_FALSA_AQUI\n-----END PRIVATE KEY-----\n","client_email":"seu-email@seu-projeto-aqui.iam.gserviceaccount.com","client_id":"123456789","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"sua-url-aqui"}